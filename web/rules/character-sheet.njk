    <!-- ── Quick Reference ──────────────────────────────── -->

    <h2 id="formulas">Quick Reference</h2>

    <table>
      <tr><th>Formula</th><th>Calculation</th></tr>
      <tr><td>Skill Target</td><td>((10 + Stat) &times; Level) + 30</td></tr>
      <tr><td>Unskilled Attempt</td><td>(5 + Stat) &times; 5</td></tr>
      <tr><td>HP per Tier</td><td>7 + BR</td></tr>
      <tr><td>EP per Tier</td><td>7 + PW</td></tr>
      <tr><td>Concentration</td><td>(PW + 4) &times; 10</td></tr>
      <tr><td>Effective Reliability</td><td>Base Reliability &minus; (Net Balance &times; 2)</td></tr>
      <tr><td>Effective Casting</td><td>Base Target + (Net Balance &times; 2)</td></tr>
    </table>
