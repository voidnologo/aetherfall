{#- ───────────────────────────────────────────────────────────────
     Aetherfall — Character Sheet Template (Nunjucks)
     Shared by blank, sample, and pre-gen character sheets.
     Data arrives via the `char` variable from 11ty pagination / frontmatter.
    ─────────────────────────────────────────────────────────────── -#}
{%- set attrKeys = ["BR","PC","IN","SP","AW","PW"] -%}
{%- set attrNames = {
  "BR": "Brawn (BR)",
  "PC": "Phys. Coordination (PC)",
  "IN": "Intellect (IN)",
  "SP": "Social Prowess (SP)",
  "AW": "Awareness (AW)",
  "PW": "Power (PW)"
} -%}

{#- Helper: resolve attribute value (null-safe) -#}
{%- macro attrVal(key) -%}
  {%- if char.attrs and char.attrs[key] and char.attrs[key].val != null -%}
    {{ char.attrs[key].val }}
  {%- endif -%}
{%- endmacro -%}

{#- Compute derived values when attributes are present -#}
{%- if char.attrs and char.attrs.BR and char.attrs.BR.val != null -%}
  {%- set brVal = char.attrs.BR.val -%}
{%- else -%}
  {%- set brVal = null -%}
{%- endif -%}

{%- if char.attrs and char.attrs.PC and char.attrs.PC.val != null -%}
  {%- set pcVal = char.attrs.PC.val -%}
{%- else -%}
  {%- set pcVal = null -%}
{%- endif -%}

{%- if char.attrs and char.attrs.IN and char.attrs.IN.val != null -%}
  {%- set inVal = char.attrs.IN.val -%}
{%- else -%}
  {%- set inVal = null -%}
{%- endif -%}

{%- if char.attrs and char.attrs.SP and char.attrs.SP.val != null -%}
  {%- set spVal = char.attrs.SP.val -%}
{%- else -%}
  {%- set spVal = null -%}
{%- endif -%}

{%- if char.attrs and char.attrs.AW and char.attrs.AW.val != null -%}
  {%- set awVal = char.attrs.AW.val -%}
{%- else -%}
  {%- set awVal = null -%}
{%- endif -%}

{%- if char.attrs and char.attrs.PW and char.attrs.PW.val != null -%}
  {%- set pwVal = char.attrs.PW.val -%}
{%- else -%}
  {%- set pwVal = null -%}
{%- endif -%}

{%- if brVal != null -%}
  {%- set netTotal = brVal + pcVal + inVal + spVal + awVal + pwVal -%}
  {%- set hpPerTier = 7 + brVal -%}
  {%- set epPerTier = 7 + pwVal -%}
  {%- set physPool = 10 + brVal + pcVal -%}
  {%- set mentalPool = 10 + inVal + awVal + pwVal -%}
  {%- set socialPool = 10 + spVal -%}
{%- else -%}
  {%- set netTotal = null -%}
  {%- set hpPerTier = null -%}
  {%- set epPerTier = null -%}
  {%- set physPool = null -%}
  {%- set mentalPool = null -%}
  {%- set socialPool = null -%}
{%- endif -%}

{#- Description lines -#}
{%- if char.description -%}
  {%- set descLines = char.description | wordcount -%}
{%- endif -%}

{#- Inventory lines -#}
{%- if char.inventory -%}
  {%- set invItems = char.inventory.split("\n") -%}
{%- else -%}
  {%- set invItems = [] -%}
{%- endif -%}

{#- Notes lines -#}
{%- if char.notes -%}
  {%- set noteItems = char.notes.split("\n") -%}
{%- else -%}
  {%- set noteItems = [] -%}
{%- endif -%}

{#- Charter lines -#}
{%- if char.society and char.society.charter -%}
  {%- set charterText = char.society.charter -%}
{%- else -%}
  {%- set charterText = "" -%}
{%- endif -%}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Aetherfall — {% if char.name %}{{ char.name }} Character Sheet{% else %}Blank Character Sheet{% endif %}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Source+Serif+4:wght@400;600;700&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        @page { size: letter portrait; margin: 0.35in; }

        body {
            font-family: 'Cormorant Garamond', 'Garamond', serif;
            font-size: 8pt;
            line-height: 1.2;
            color: #1a1a1a;
            background: #fff;
        }

        .page {
            width: 7.5in;
            height: 10.0in;
            margin: 0 auto;
            page-break-after: always;
            overflow: hidden;
            position: relative;
        }
        .page:last-child { page-break-after: avoid; }

        /* -- Watermark -- */
        .page-watermark {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
            object-position: left top;
            opacity: 0.06;
            pointer-events: none;
            z-index: 0;
        }
        .page > *:not(.page-watermark) { position: relative; z-index: 1; }

        /* -- Art Deco Borders -- */
        .page::before {
            content: '';
            position: absolute;
            inset: 4pt;
            border: 1.5pt solid #2a2a2a;
            pointer-events: none;
            z-index: 2;
        }
        .page::after {
            content: '';
            position: absolute;
            inset: 7pt;
            border: 0.5pt solid #999;
            pointer-events: none;
            z-index: 2;
        }
        .page { padding: 12pt 14pt; }

        /* -- Art Deco Dividers -- */
        .deco-rule {
            text-align: center;
            font-size: 8pt;
            color: #999;
            letter-spacing: 4pt;
            margin: 2pt 0;
            line-height: 1;
        }

        /* -- Sections -- */
        .section {
            border: 1pt solid #555;
            padding: 3pt 5pt;
            margin-bottom: 3pt;
            position: relative;
        }
        .section::before {
            content: '';
            position: absolute;
            top: -1pt; left: -1pt; right: -1pt; bottom: -1pt;
        }
        .section-title {
            font-family: 'Playfair Display', serif;
            font-size: 7.5pt;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1.5pt;
            margin-bottom: 2pt;
            color: #222;
            border-bottom: 1pt solid #333;
            padding-bottom: 1.5pt;
        }

        /* -- Header -- */
        .header {
            display: grid;
            grid-template-columns: 1fr 1fr 1fr;
            gap: 6pt;
            margin-bottom: 3pt;
            border: 1.5pt solid #2a2a2a;
            padding: 4pt 6pt;
        }
        /* -- Wordmark -- */
        .sheet-wordmark {
            text-align: center;
            margin: -4pt 0 3pt;
        }
        .sheet-wordmark img {
            width: 3in;
            height: auto;
            display: inline-block;
            filter: brightness(0);
        }
        .field { display: flex; flex-direction: column; }
        .field-label {
            font-family: 'Playfair Display', serif;
            font-size: 5.5pt;
            text-transform: uppercase;
            letter-spacing: 1pt;
            color: #555;
            margin-bottom: 0.5pt;
        }
        .field-line {
            border-bottom: 0.75pt solid #888;
            min-height: 11pt;
            font-family: 'Cormorant Garamond', serif;
            font-size: 8.5pt;
        }

        /* -- Layout -- */
        .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 3pt; }

        /* -- Attributes -- */
        .attr-table { width: 100%; border-collapse: collapse; }
        .attr-table th {
            font-family: 'Playfair Display', serif;
            font-size: 5.5pt; text-transform: uppercase; color: #555;
            font-weight: 600; padding: 0.5pt 1pt; text-align: center;
            letter-spacing: 0.5pt;
        }
        .attr-table th:first-child { text-align: left; }
        .attr-table td { padding: 1pt 1pt; text-align: center; font-size: 8pt; }
        .attr-table td:first-child {
            text-align: left; font-weight: 600; font-size: 7pt;
            font-family: 'Cormorant Garamond', serif;
        }
        .attr-table td:last-child { text-align: left; }
        .attr-bubble {
            display: inline-block; width: 9pt; height: 9pt;
            border: 0.75pt solid #444; border-radius: 50%; margin: 0 0.25pt;
        }
        .attr-bubble.marked {
            background: #2a2a2a;
        }
        .attr-desc-line {
            border-bottom: 0.5pt solid #aaa; width: 100%;
            min-height: 10pt; display: inline-block;
        }
        .derived-row {
            display: flex; justify-content: space-between;
            margin-top: 2pt; padding-top: 2pt;
            border-top: 0.75pt solid #bbb; font-size: 7pt;
        }
        .derived-item { display: flex; align-items: center; gap: 2pt; }
        .derived-label {
            font-family: 'Playfair Display', serif;
            font-weight: 600; color: #444; font-size: 6pt;
            text-transform: uppercase; letter-spacing: 0.5pt;
        }
        .derived-box {
            width: 22pt; height: 12pt;
            border: 0.75pt solid #888; text-align: center;
            font-family: 'Cormorant Garamond', serif; font-size: 8pt;
        }

        /* -- Health/Exhaustion -- */
        .track-section { display: grid; grid-template-columns: 1fr 1fr; gap: 3pt; }
        .track {
            border: 1pt solid #555; padding: 3pt 4pt;
        }
        .track-title {
            font-family: 'Playfair Display', serif;
            font-size: 7pt; font-weight: 700; text-transform: uppercase;
            letter-spacing: 1pt; margin-bottom: 2pt; color: #222;
        }
        .track-formula {
            font-family: 'Cormorant Garamond', serif;
            font-size: 6.5pt; color: #777; font-weight: 400;
        }
        .tier { display: flex; align-items: center; margin-bottom: 1pt; gap: 2pt; }
        .tier-boxes { display: flex; gap: 1pt; flex-shrink: 0; }
        .hp-box {
            width: 9pt; height: 9pt;
            border: 0.75pt solid #444;
        }
        .hp-box.crossed {
            background: repeating-linear-gradient(
                45deg, transparent, transparent 2pt, #bbb 2pt, #bbb 3pt
            );
        }
        .tier-label {
            font-family: 'Playfair Display', serif;
            font-size: 6.5pt; font-weight: 600; white-space: nowrap;
        }
        .tier-penalty { font-size: 6.5pt; color: #888; }
        .track-notes { margin-top: 1pt; border-top: 0.5pt solid #bbb; padding-top: 1pt; }
        .track-notes-label {
            font-family: 'Playfair Display', serif;
            font-size: 6pt; color: #555; font-weight: 600;
            text-transform: uppercase; letter-spacing: 0.5pt;
        }
        .death-saves {
            display: flex; align-items: center; gap: 2pt;
            margin-top: 1pt; padding-top: 1pt;
            border-top: 0.5pt solid #bbb; font-size: 7pt;
        }
        .death-save-box {
            width: 10pt; height: 10pt; border: 0.75pt solid #444;
        }

        /* -- Skills -- */
        .skill-table { width: 100%; border-collapse: collapse; }
        .skill-table th {
            font-family: 'Playfair Display', serif;
            font-size: 5.5pt; text-transform: uppercase; color: #555;
            font-weight: 600; padding: 0.5pt 2pt;
            border-bottom: 0.75pt solid #888;
            letter-spacing: 0.5pt;
        }
        .skill-table td {
            padding: 1.5pt 2pt; font-size: 7.5pt;
            border-bottom: 0.5pt solid #ccc;
            font-family: 'Cormorant Garamond', serif;
        }
        .skill-table .total-cell {
            border: 0.75pt solid #888;
            width: 28pt; text-align: center;
        }
        .skill-pool-summary {
            display: flex; justify-content: space-between;
            font-size: 6.5pt; color: #555;
            margin-top: 2pt; padding-top: 1pt;
            border-top: 0.5pt solid #bbb;
            font-family: 'Playfair Display', serif;
            text-transform: uppercase; letter-spacing: 0.5pt;
        }

        /* -- Weapons -- */
        .weapon-table, .armor-table, .spell-table {
            width: 100%; border-collapse: collapse; font-size: 7.5pt;
            font-family: 'Cormorant Garamond', serif;
        }
        .weapon-table th, .armor-table th, .spell-table th {
            font-family: 'Playfair Display', serif;
            font-size: 5.5pt; text-transform: uppercase; color: #555;
            font-weight: 600; padding: 0.5pt 2pt;
            border-bottom: 0.75pt solid #888; text-align: center;
            letter-spacing: 0.5pt;
        }
        .weapon-table th:first-child, .armor-table th:first-child,
        .spell-table th:first-child { text-align: left; }
        .weapon-table td, .armor-table td, .spell-table td {
            padding: 1.5pt 2pt; border-bottom: 0.5pt solid #ccc; text-align: center;
        }
        .weapon-table td:first-child, .armor-table td:first-child,
        .spell-table td:first-child { text-align: left; }
        .weapon-prefill { color: #999; font-size: 7pt; }

        /* -- Inventory -- */
        .inv-line { border-bottom: 0.5pt solid #bbb; min-height: 11pt; }

        /* -- Notes -- */
        .notes-line { border-bottom: 0.5pt solid #bbb; min-height: 11pt; }

        /* -- Reference box -- */
        .reference-box {
            background: #f7f5f0; border: 0.75pt solid #bbb;
            padding: 3pt 4pt;
            font-size: 6.5pt; color: #444; line-height: 1.3;
        }
        .reference-box code {
            font-family: 'JetBrains Mono', 'Consolas', monospace;
            font-size: 6pt; color: #333;
            background: #e8e4dc; padding: 0 1pt;
        }

        /* -- XP -- */
        .xp-grid {
            display: grid; grid-template-columns: auto 1fr auto 1fr;
            gap: 1pt 4pt; align-items: center; font-size: 7.5pt;
        }
        .xp-label {
            font-family: 'Playfair Display', serif;
            font-weight: 600; color: #444; font-size: 6pt;
            text-transform: uppercase; letter-spacing: 0.5pt;
        }
        .xp-box { height: 12pt; border: 0.75pt solid #888; }

        /* -- Casting -- */
        .casting-grid {
            display: grid; grid-template-columns: 1fr 1fr;
            gap: 2pt 6pt; font-size: 7.5pt;
        }
        .casting-field { display: flex; align-items: center; gap: 2pt; }
        .casting-label {
            font-family: 'Playfair Display', serif;
            font-weight: 600; color: #444; font-size: 6pt; white-space: nowrap;
            text-transform: uppercase; letter-spacing: 0.5pt;
        }
        .casting-value {
            flex: 1; border-bottom: 0.75pt solid #aaa; min-height: 10pt;
            font-family: 'Cormorant Garamond', serif; font-size: 8pt;
        }
        .checkbox-row { display: flex; gap: 6pt; align-items: center; font-size: 7.5pt; }
        .checkbox-item { display: flex; align-items: center; gap: 1.5pt; }
        .checkbox {
            width: 8pt; height: 8pt; border: 0.75pt solid #444;
            flex-shrink: 0;
        }
        .checkbox.checked {
            background: #2a2a2a;
        }

        /* -- Society -- */
        .society-grid {
            display: grid; grid-template-columns: 1fr 1fr; gap: 2pt 6pt;
        }

        /* -- Contacts -- */
        .contact-row {
            display: grid; grid-template-columns: 1fr 1fr 2fr;
            gap: 3pt; margin-bottom: 0.5pt;
        }
        .contact-row .field-line { min-height: 10pt; }

        /* -- Print -- */
        @media print {
            body { background: none; }
            .page { width: auto; height: auto; margin: 0; }
            .no-print { display: none; }
            .page-watermark { opacity: 0.05; }
            .sheet-wordmark img { filter: brightness(0); }
        }

        /* -- Screen -- */
        @media screen {
            body {
                background: #0e1117; padding: 2rem;
                font-family: 'Source Serif 4', 'Cormorant Garamond', serif;
            }
            .tool-header {
                text-align: center; margin-bottom: 2rem;
            }
            .tool-header h1 {
                font-family: 'Playfair Display', serif;
                font-size: 2rem; font-weight: 900;
                color: #eef0f5; margin-bottom: 0.3rem;
                letter-spacing: 0.1em;
            }
            .tool-header p {
                font-family: 'Cormorant Garamond', serif;
                color: #8a92a4; font-size: 1rem;
            }
            .tool-header a {
                font-family: 'Cormorant Garamond', serif;
                color: #8a92a4; text-decoration: none; font-size: 0.9rem;
                letter-spacing: 0.05em;
            }
            .tool-header a:hover { color: #eef0f5; }
            .tool-header button {
                font-family: 'Playfair Display', serif;
                background: #3dc8e0; color: #080b14; border: none;
                padding: 8px 24px; cursor: pointer;
                font-weight: 700; font-size: 13px; margin-top: 0.75rem;
                letter-spacing: 0.1em; text-transform: uppercase;
            }
            .tool-header button:hover { background: #5dd8ec; }
            .page {
                background: #fff; box-shadow: 0 4px 16px rgba(0,0,0,0.4);
                margin: 0 auto 20px; padding: 0.35in;
            }
        }
    </style>
</head>
<body>

{#- ── Screen Header (hidden on print) ── -#}
<div class="tool-header no-print">
    <a href="../character-sheet.html">&larr; Back to Character Sheet</a>
    <h1>{% if char.name %}{{ char.name }}{% else %}Blank Character Sheet{% endif %}</h1>
    <p>Print this page or save as PDF for a {% if char.name %}pre-generated{% else %}blank{% endif %} two-page character sheet</p>
    <button onclick="window.print()">Print / Save PDF</button>
</div>

{#- ═══════════════ PAGE 1 ═══════════════ -#}
<div class="page">
    <img src="{{ '/assets/art/fantasy.jpg' | url }}" alt="" class="page-watermark">

    {#- ── Wordmark ── -#}
    <div class="sheet-wordmark">
        <img src="{{ '/assets/logo/wordmark.webp' | url }}" alt="Aetherfall">
    </div>

    {#- ── Header ── -#}
    <div class="header">
        <div class="field">
            <div class="field-label">Character Name</div>
            <div class="field-line">{{ char.name | default("") }}</div>
        </div>
        <div class="field">
            <div class="field-label">Player</div>
            <div class="field-line">{{ char.player | default("") }}</div>
        </div>
        <div style="display:grid;grid-template-columns:1fr auto;gap:6pt;">
            <div class="field">
                <div class="field-label">Archetype</div>
                <div class="field-line">{{ char.archetype | default("") }}</div>
            </div>
            <div class="field" style="text-align:center;">
                <div class="field-label">Station</div>
                <div class="field-line" style="min-width:28pt;">{% if char.station %}{{ char.station }}{% endif %}</div>
            </div>
        </div>
    </div>

    <div class="two-col">
        {#- ── Left Column ── -#}
        <div>

            {#- Attributes -#}
            <div class="section">
                <div class="section-title">Attributes</div>
                <table class="attr-table">
                    <thead>
                        <tr>
                            <th style="width:34%;">Attribute</th>
                            <th>-3</th><th>-2</th><th>-1</th><th>0</th><th>+1</th><th>+2</th><th>+3</th>
                            <th style="width:26%;">Description</th>
                        </tr>
                    </thead>
                    <tbody>
                        {%- for key in attrKeys %}
                        <tr>
                            <td>{{ attrNames[key] }}</td>
                            {%- for v in range(-3, 4) %}
                            <td><span class="attr-bubble{% if char.attrs and char.attrs[key] and char.attrs[key].val == v %} marked{% endif %}"></span></td>
                            {%- endfor %}
                            <td><span class="attr-desc-line">{% if char.attrs and char.attrs[key] and char.attrs[key].desc %}{{ char.attrs[key].desc }}{% endif %}</span></td>
                        </tr>
                        {%- endfor %}
                    </tbody>
                </table>
                <div class="derived-row">
                    <div class="derived-item">
                        <span class="derived-label">Net Total:</span>
                        <div class="derived-box">{% if netTotal != null %}{{ netTotal }}{% endif %}</div>
                    </div>
                    <div class="derived-item">
                        <span class="derived-label">HP/Tier:</span>
                        <div class="derived-box">{% if hpPerTier != null %}{{ hpPerTier }}{% endif %}</div>
                        <span style="font-size:6pt;color:#888;">(7+BR)</span>
                    </div>
                    <div class="derived-item">
                        <span class="derived-label">EP/Tier:</span>
                        <div class="derived-box">{% if epPerTier != null %}{{ epPerTier }}{% endif %}</div>
                        <span style="font-size:6pt;color:#888;">(7+PW)</span>
                    </div>
                </div>
            </div>

            {#- Weapons -#}
            <div class="section">
                <div class="section-title">Weapons</div>
                <table class="weapon-table">
                    <thead>
                        <tr>
                            <th style="width:26%;text-align:left;">Weapon</th>
                            <th style="width:10%;">Skill</th>
                            <th style="width:7%;">Spd</th>
                            <th style="width:13%;">Damage</th>
                            <th style="width:7%;">Cap</th>
                            <th style="width:7%;">Rld</th>
                            <th style="width:9%;">Rel%</th>
                            <th style="width:21%;">Tags</th>
                        </tr>
                    </thead>
                    <tbody>
                        {#- Unarmed is always first row, prefilled and grey -#}
                        <tr>
                            <td class="weapon-prefill">Unarmed</td>
                            <td class="weapon-prefill">Brawl</td>
                            <td class="weapon-prefill">2</td>
                            <td class="weapon-prefill">1d3+BR</td>
                            <td class="weapon-prefill">&mdash;</td>
                            <td class="weapon-prefill">&mdash;</td>
                            <td class="weapon-prefill">&mdash;</td>
                            <td></td>
                        </tr>
                        {%- set weaponSlots = 5 -%}
                        {%- set weaponCount = char.weapons | length if char.weapons else 0 -%}
                        {%- for weapon in char.weapons %}
                        <tr>
                            <td>{{ weapon.name }}</td>
                            <td>{{ weapon.skill }}</td>
                            <td>{{ weapon.spd }}</td>
                            <td>{{ weapon.dmg }}</td>
                            <td>{{ weapon.cap | default("&mdash;") | safe }}</td>
                            <td>{{ weapon.rld | default("&mdash;") | safe }}</td>
                            <td>{{ weapon.rel | default("&mdash;") | safe }}</td>
                            <td>{{ weapon.tags | default("") }}</td>
                        </tr>
                        {%- endfor %}
                        {%- for i in range(weaponCount, weaponSlots) %}
                        <tr><td>&nbsp;</td><td></td><td></td><td></td><td></td><td></td><td></td><td></td></tr>
                        {%- endfor %}
                    </tbody>
                </table>
            </div>

            {#- Armor -#}
            <div class="section">
                <div class="section-title">Armor &amp; Defense</div>
                <table class="armor-table">
                    <thead>
                        <tr>
                            <th style="width:30%;text-align:left;">Armor / Shield</th>
                            <th style="width:15%;">Ballistic</th>
                            <th style="width:15%;">Martial</th>
                            <th style="width:15%;">Hinder</th>
                            <th style="width:25%;">Notes</th>
                        </tr>
                    </thead>
                    <tbody>
                        {%- set armorSlots = 3 -%}
                        {%- set armorCount = char.armor | length if char.armor else 0 -%}
                        {%- for piece in char.armor %}
                        <tr>
                            <td>{{ piece.name }}</td>
                            <td>{{ piece.ballistic }}</td>
                            <td>{{ piece.martial }}</td>
                            <td>{{ piece.hinder }}</td>
                            <td>{{ piece.notes | default("") }}</td>
                        </tr>
                        {%- endfor %}
                        {%- for i in range(armorCount, armorSlots) %}
                        <tr><td>&nbsp;</td><td></td><td></td><td></td><td></td></tr>
                        {%- endfor %}
                    </tbody>
                </table>
                {%- set totalBallistic = 0 -%}
                {%- set totalMartial = 0 -%}
                {%- set totalHinder = 0 -%}
                {%- for piece in char.armor %}
                  {%- set totalBallistic = totalBallistic + piece.ballistic -%}
                  {%- set totalMartial = totalMartial + piece.martial -%}
                  {%- set totalHinder = totalHinder + piece.hinder -%}
                {%- endfor %}
                <div class="derived-row" style="margin-top:2pt;">
                    <div class="derived-item">
                        <span class="derived-label">Total Ballistic:</span>
                        <div class="derived-box">{% if armorCount > 0 %}{{ totalBallistic }}{% endif %}</div>
                    </div>
                    <div class="derived-item">
                        <span class="derived-label">Total Martial:</span>
                        <div class="derived-box">{% if armorCount > 0 %}{{ totalMartial }}{% endif %}</div>
                    </div>
                    <div class="derived-item">
                        <span class="derived-label">Total Hinder:</span>
                        <div class="derived-box">{% if armorCount > 0 %}{{ totalHinder }}{% endif %}</div>
                    </div>
                </div>
            </div>

        </div>

        {#- ── Right Column ── -#}
        <div>

            {#- Character Description -#}
            <div class="section">
                <div class="section-title">Character Description</div>
                {%- if char.description %}
                <div class="notes-line">{{ char.description }}</div>
                {%- for i in range(0, 2) %}
                <div class="notes-line"></div>
                {%- endfor %}
                {%- else %}
                {%- for i in range(0, 3) %}
                <div class="notes-line"></div>
                {%- endfor %}
                {%- endif %}
            </div>

            {#- Skills -#}
            <div class="section">
                <div class="section-title">Skills <span style="font-weight:400;font-size:6.5pt;color:#888;">&mdash; Target = ((10 + Stat) &times; Level) + 30 &nbsp;|&nbsp; Max 15</span></div>
                <table class="skill-table">
                    <thead>
                        <tr>
                            <th style="width:44%;text-align:left;">Skill</th>
                            <th style="width:14%;text-align:center;">Stat</th>
                            <th style="width:14%;text-align:center;">Lvl</th>
                            <th style="width:28%;text-align:center;">Target</th>
                        </tr>
                    </thead>
                    <tbody>
                        {%- set skillSlots = 15 -%}
                        {%- set skillCount = char.skills | length if char.skills else 0 -%}
                        {%- for skill in char.skills %}
                        <tr>
                            <td><div class="field-line">{{ skill.name }}</div></td>
                            <td><div class="field-line" style="text-align:center;">{{ skill.stat }}({% if char.attrs and char.attrs[skill.stat] %}{{ char.attrs[skill.stat].val }}{% endif %})</div></td>
                            <td><div class="field-line" style="text-align:center;">{{ skill.level }}</div></td>
                            <td class="total-cell">{{ skill.target }}</td>
                        </tr>
                        {%- endfor %}
                        {%- for i in range(skillCount, skillSlots) %}
                        <tr>
                            <td><div class="field-line"></div></td>
                            <td><div class="field-line"></div></td>
                            <td><div class="field-line"></div></td>
                            <td class="total-cell"></td>
                        </tr>
                        {%- endfor %}
                    </tbody>
                </table>
                <div class="skill-pool-summary">
                    <span><strong>Physical:</strong> 10+BR+PC = {% if physPool != null %}{{ physPool }}{% else %}___{% endif %}</span>
                    <span><strong>Mental:</strong> 10+IN+AW+PW = {% if mentalPool != null %}{{ mentalPool }}{% else %}___{% endif %}</span>
                    <span><strong>Social:</strong> 10+SP = {% if socialPool != null %}{{ socialPool }}{% else %}___{% endif %}</span>
                </div>
            </div>

            {#- XP -#}
            <div class="section">
                <div class="section-title">Experience</div>
                <div class="xp-grid">
                    <span class="xp-label">Total XP:</span>
                    <div class="xp-box">{% if char.xp and char.xp.total %}{{ char.xp.total }}{% endif %}</div>
                    <span class="xp-label">XP Spent:</span>
                    <div class="xp-box">{% if char.xp and char.xp.spent %}{{ char.xp.spent }}{% endif %}</div>
                </div>
                <div style="font-size:6pt;color:#888;margin-top:1pt;">
                    Skill 0&rarr;1: 1 XP &middot; 1&rarr;2: 2 &middot; 2&rarr;3: 3 &middot; 3&rarr;4: 4 &middot; 4&rarr;5: 5 &middot; Attribute +1: 10 XP
                </div>
            </div>

        </div>
    </div>

    {#- Wound & Exhaustion Tracks -- full width below the two-col grid -#}
    <div class="track-section">
        {#- Wounds -#}
        <div class="track">
            <div class="track-title">Wounds <span class="track-formula">(7+BR per tier)</span></div>
            {%- set woundTiers = [
                {"label": "OK", "penalty": ""},
                {"label": "Harmed", "penalty": "-10%"},
                {"label": "Maimed", "penalty": "-25%"},
                {"label": "Incap.", "penalty": "-50%"}
            ] -%}
            {%- for tier in woundTiers %}
            <div class="tier">
                <div class="tier-boxes">
                    {%- for b in range(0, 10) %}
                    <div class="hp-box{% if hpPerTier != null and b >= hpPerTier %} crossed{% endif %}"></div>
                    {%- endfor %}
                </div>
                <span class="tier-label">{{ tier.label }}{% if tier.penalty %} <span class="tier-penalty">{{ tier.penalty }}</span>{% endif %}</span>
            </div>
            {%- endfor %}
            <div class="death-saves">
                <span style="font-weight:600;font-size:6.5pt;">Death Saves:</span>
                <div class="death-save-box"></div>
                <div class="death-save-box"></div>
                <div class="death-save-box"></div>
            </div>
            <div class="track-notes">
                <div class="track-notes-label">Injuries:</div>
                <div style="min-height:14pt;"></div>
            </div>
        </div>

        {#- Exhaustion -#}
        <div class="track">
            <div class="track-title">Exhaustion <span class="track-formula">(7+PW per tier)</span></div>
            {%- set exhaustTiers = [
                {"label": "OK", "penalty": ""},
                {"label": "Wearied", "penalty": "-10%"},
                {"label": "Drained", "penalty": "-25%"},
                {"label": "Overwhelmed", "penalty": "-50%"}
            ] -%}
            {%- for tier in exhaustTiers %}
            <div class="tier">
                <div class="tier-boxes">
                    {%- for b in range(0, 10) %}
                    <div class="hp-box{% if epPerTier != null and b >= epPerTier %} crossed{% endif %}"></div>
                    {%- endfor %}
                </div>
                <span class="tier-label">{{ tier.label }}{% if tier.penalty %} <span class="tier-penalty">{{ tier.penalty }}</span>{% endif %}</span>
            </div>
            {%- endfor %}
            <div class="track-notes">
                <div class="track-notes-label">Effects:</div>
                <div style="min-height:14pt;"></div>
            </div>
        </div>
    </div>

</div>

{#- ═══════════════ PAGE 2 ═══════════════ -#}
<div class="page">
    <img src="{{ '/assets/art/fantasy.jpg' | url }}" alt="" class="page-watermark">

    <div class="two-col">

        {#- ── Left Column ── -#}
        <div>

            {#- Magic -#}
            <div class="section">
                <div class="section-title">Magic</div>
                <div class="checkbox-row" style="margin-bottom:2pt;">
                    <span style="font-weight:600;font-size:7pt;color:#555;">Path:</span>
                    <div class="checkbox-item"><div class="checkbox{% if char.path == 'scholarly' %} checked{% endif %}"></div><span>Scholarly</span></div>
                    <div class="checkbox-item"><div class="checkbox{% if char.path == 'wild' %} checked{% endif %}"></div><span>Wild</span></div>
                    <div class="checkbox-item"><div class="checkbox{% if char.path == 'none' %} checked{% endif %}"></div><span>Non-caster</span></div>
                </div>
                <div class="casting-grid">
                    <div class="casting-field">
                        <span class="casting-label">Casting Target:</span>
                        <div class="casting-value">
                            {%- if char.path == 'scholarly' or char.path == 'wild' -%}
                                {%- if char.skills -%}
                                    {%- for skill in char.skills -%}
                                        {%- if skill.name == 'Casting' or skill.name == 'Spellcasting' %}{{ skill.target }}{% endif -%}
                                    {%- endfor -%}
                                {%- endif -%}
                            {%- endif -%}
                        </div>
                    </div>
                    <div class="casting-field">
                        <span class="casting-label">Concentration:</span>
                        <div class="casting-value">{% if pwVal != null and (char.path == 'scholarly' or char.path == 'wild') %}{{ (pwVal + 4) * 10 }}{% endif %}</div>
                        <span style="font-size:6pt;color:#888;">(PW+4)&times;10</span>
                    </div>
                    <div class="casting-field">
                        <span class="casting-label">Schools:</span>
                        <div class="casting-value">
                            {%- if char.path == 'scholarly' -%}
                                All
                            {%- elif char.path == 'wild' and char.wildSchools -%}
                                {{ char.wildSchools | join(", ") }}
                            {%- endif -%}
                        </div>
                    </div>
                    <div class="casting-field">
                        <span class="casting-label">Spells Known:</span>
                        <div class="casting-value">{% if pwVal != null and (char.path == 'scholarly' or char.path == 'wild') %}{{ 7 + pwVal }}{% endif %}</div>
                        <span style="font-size:6pt;color:#888;">(7+PW)</span>
                    </div>
                </div>
                <div style="font-size:6pt;color:#888;margin-top:2pt;">
                    Backlash: Scholarly 5/10/15/25% by tier &middot; Wild +5% flat/tier &middot;
                    On backlash: 1d4 HP + 25% wild effect
                </div>
            </div>

            {#- Spells -#}
            <div class="section">
                <div class="section-title">Spells</div>
                <table class="spell-table">
                    <thead>
                        <tr>
                            <th style="width:28%;text-align:left;">Spell</th>
                            <th style="width:18%;">School</th>
                            <th style="width:9%;">Cast</th>
                            <th style="width:11%;">W</th>
                            <th style="width:11%;">S</th>
                            <th style="width:11%;">St</th>
                            <th style="width:12%;">Sp</th>
                        </tr>
                    </thead>
                    <tbody>
                        {%- set spellSlots = 12 -%}
                        {%- set spellCount = char.spells | length if char.spells else 0 -%}
                        {%- for spell in char.spells %}
                        <tr>
                            <td>{{ spell.name }}</td>
                            <td>{{ spell.school }}</td>
                            <td>{{ spell.cast }}</td>
                            <td>{{ spell.w }}</td>
                            <td>{{ spell.s }}</td>
                            <td>{{ spell.st }}</td>
                            <td>{{ spell.sp }}</td>
                        </tr>
                        {%- endfor %}
                        {%- for i in range(spellCount, spellSlots) %}
                        <tr><td>&nbsp;</td><td></td><td></td><td></td><td></td><td></td><td></td></tr>
                        {%- endfor %}
                    </tbody>
                </table>
                <div style="font-size:6pt;color:#888;margin-top:1pt;">
                    Cast = time (counts) &middot; W/S/St/Sp = Weak/Standard/Strong/Spectacular exhaustion cost
                </div>
            </div>

            {#- Inventory -#}
            <div class="section">
                <div class="section-title">Inventory</div>
                {%- set invSlots = 12 -%}
                {%- for item in invItems %}
                <div class="inv-line">{{ item }}</div>
                {%- endfor %}
                {%- for i in range(invItems | length, invSlots) %}
                <div class="inv-line"></div>
                {%- endfor %}
            </div>

        </div>

        {#- ── Right Column ── -#}
        <div>

            {#- Society -#}
            <div class="section">
                <div class="section-title">Adventuring Society</div>
                <div class="society-grid">
                    <div class="field">
                        <div class="field-label">Society Name</div>
                        <div class="field-line">{% if char.society %}{{ char.society.name | default("") }}{% endif %}</div>
                    </div>
                    <div class="field">
                        <div class="field-label">Society Type</div>
                        <div class="field-line">{% if char.society %}{{ char.society.type | default("") }}{% endif %}</div>
                    </div>
                    <div class="field">
                        <div class="field-label">Patron</div>
                        <div class="field-line">{% if char.society %}{{ char.society.patron | default("") }}{% endif %}</div>
                    </div>
                    <div class="field">
                        <div class="field-label">Handler</div>
                        <div class="field-line">{% if char.society %}{{ char.society.handler | default("") }}{% endif %}</div>
                    </div>
                    <div class="field">
                        <div class="field-label">Backing (1&ndash;5)</div>
                        <div class="field-line">{% if char.society and char.society.backing %}{{ char.society.backing }}{% endif %}</div>
                    </div>
                    <div class="field">
                        <div class="field-label">Ledger</div>
                        <div class="field-line" style="font-size:6pt;">
                            {%- set ledgerLevels = ["Flush", "Level", "Lean", "Dire"] -%}
                            {%- set activeLedger = char.society.ledger if char.society else "" -%}
                            {%- for level in ledgerLevels -%}
                                {%- if activeLedger == level -%}&#9746;{%- else -%}&#9744;{%- endif %} {{ level }}{%- if not loop.last %} &nbsp; {% endif -%}
                            {%- endfor -%}
                        </div>
                    </div>
                </div>
                <div class="field" style="margin-top:2pt;">
                    <div class="field-label">Charter / Mission</div>
                    <div class="field-line">{{ charterText }}</div>
                    <div class="field-line"></div>
                </div>
            </div>

            {#- Faction -#}
            <div class="section">
                <div class="section-title">Faction Alignment</div>
                <div class="field">
                    <div class="field-label">Primary Faction</div>
                    <div class="field-line">{{ char.faction | default("") }}</div>
                </div>
                <div class="field" style="margin-top:2pt;">
                    <div class="field-label">Relationship / Standing</div>
                    <div class="field-line">{{ char.factionRelation | default("") }}</div>
                    <div class="field-line"></div>
                </div>
            </div>

            {#- Contacts -#}
            <div class="section">
                <div class="section-title">Notable Contacts</div>
                <div style="display:grid;grid-template-columns:2fr 1.5fr 3fr;gap:1pt;font-size:6pt;color:#666;font-weight:600;text-transform:uppercase;margin-bottom:1pt;">
                    <span>Name</span><span>Affiliation</span><span>Notes</span>
                </div>
                {%- set contactSlots = 6 -%}
                {%- set contactCount = char.contacts | length if char.contacts else 0 -%}
                {%- for contact in char.contacts %}
                <div class="contact-row">
                    <div class="field-line">{{ contact.name }}</div>
                    <div class="field-line">{{ contact.affiliation }}</div>
                    <div class="field-line">{{ contact.notes }}</div>
                </div>
                {%- endfor %}
                {%- for i in range(contactCount, contactSlots) %}
                <div class="contact-row">
                    <div class="field-line"></div>
                    <div class="field-line"></div>
                    <div class="field-line"></div>
                </div>
                {%- endfor %}
            </div>

            {#- Backlash -#}
            <div class="section">
                <div class="section-title">Active Backlash Effects</div>
                <div class="notes-line"></div>
                <div class="notes-line"></div>
                <div class="notes-line"></div>
            </div>

            {#- Notes -#}
            <div class="section">
                <div class="section-title">Notes</div>
                {%- set noteSlots = 13 -%}
                {%- for note in noteItems %}
                <div class="notes-line">{{ note }}</div>
                {%- endfor %}
                {%- for i in range(noteItems | length, noteSlots) %}
                <div class="notes-line"></div>
                {%- endfor %}
            </div>

        </div>
    </div>

    {#- Quick Reference -#}
    <div class="reference-box" style="margin-top:3pt;">
        <strong>Quick Reference</strong> &mdash;
        <code>Skill Target = ((10 + Stat) &times; Level) + 30</code> &middot;
        <code>Unskilled = (5 + Stat) &times; 5</code> &middot;
        <code>Concentration = (PW + 4) &times; 10</code> &middot;
        <code>Eff. Reliability = Base &minus; (Balance &times; 2)</code> &middot;
        <code>Eff. Casting = Base + (Balance &times; 2)</code> &middot;
        Wound &amp; Exhaustion penalties stack &middot;
        Hinder: &minus;5% to PC-skills, +1 cast speed/pt
    </div>

</div>

<script>
// If character data was passed via sessionStorage (from the builder's Print button),
// populate this sheet and trigger print. This lets the builder use the same template
// as the build-time sheets — zero duplication.
(function() {
  var raw = localStorage.getItem('aetherfall-print');
  if (!raw) return;
  localStorage.removeItem('aetherfall-print');

  try { var c = JSON.parse(raw); } catch(e) { return; }

  // Helper: set text of first matching element
  function setText(selector, val) {
    var el = document.querySelector(selector);
    if (el && val) el.textContent = val;
  }

  // Helper: set all field-line values in a parent
  function fillFieldLines(parentSelector, values) {
    var lines = document.querySelectorAll(parentSelector + ' .field-line');
    for (var i = 0; i < lines.length && i < values.length; i++) {
      if (values[i]) lines[i].textContent = values[i];
    }
  }

  // Update screen header
  var h1 = document.querySelector('.tool-header h1');
  if (h1 && c.name) h1.textContent = c.name;

  // Header fields
  var headers = document.querySelectorAll('.header .field-line');
  if (headers[0]) headers[0].textContent = c.name || '';
  if (headers[1]) headers[1].textContent = c.player || '';
  if (headers[2]) headers[2].textContent = c.archetype || '';
  if (headers[3]) headers[3].textContent = c.station != null ? c.station : '';

  // Attributes: mark bubbles
  var attrKeys = ['BR','PC','IN','SP','AW','PW'];
  var attrRows = document.querySelectorAll('.attr-table tbody tr');
  var brVal = 0, pcVal = 0, inVal = 0, spVal = 0, awVal = 0, pwVal = 0;
  attrRows.forEach(function(row, idx) {
    var key = attrKeys[idx];
    if (!c.attrs || !c.attrs[key]) return;
    var val = c.attrs[key].val;
    if (val == null) return;

    // Store for derived calcs
    if (key === 'BR') brVal = val;
    if (key === 'PC') pcVal = val;
    if (key === 'IN') inVal = val;
    if (key === 'SP') spVal = val;
    if (key === 'AW') awVal = val;
    if (key === 'PW') pwVal = val;

    var bubbles = row.querySelectorAll('.attr-bubble');
    bubbles.forEach(function(b, bi) {
      if (bi === val + 3) b.classList.add('marked');
    });

    var descLine = row.querySelector('.attr-desc-line');
    if (descLine && c.attrs[key].desc) descLine.textContent = c.attrs[key].desc;
  });

  // Derived values
  var derivedBoxes = document.querySelectorAll('.derived-box');
  var netTotal = brVal + pcVal + inVal + spVal + awVal + pwVal;
  var hpPerTier = 7 + brVal;
  var epPerTier = 7 + pwVal;
  if (derivedBoxes[0]) derivedBoxes[0].textContent = (netTotal >= 0 ? '+' : '') + netTotal;
  if (derivedBoxes[1]) derivedBoxes[1].textContent = hpPerTier;
  if (derivedBoxes[2]) derivedBoxes[2].textContent = epPerTier;

  // Description
  var descLines = document.querySelectorAll('.section-title');
  descLines.forEach(function(title) {
    if (title.textContent.trim() === 'Character Description') {
      var lines = title.parentElement.querySelectorAll('.notes-line');
      if (lines[0] && c.description) lines[0].textContent = c.description;
    }
  });

  // Skills
  var skillRows = document.querySelectorAll('.skill-table tbody tr');
  (c.skills || []).forEach(function(skill, i) {
    if (!skillRows[i]) return;
    var cells = skillRows[i].querySelectorAll('.field-line');
    if (cells[0]) cells[0].textContent = skill.name;
    if (cells[1]) { cells[1].textContent = skill.stat + '(' + (c.attrs[skill.stat] ? c.attrs[skill.stat].val : 0) + ')'; cells[1].style.textAlign = 'center'; }
    if (cells[2]) { cells[2].textContent = skill.level; cells[2].style.textAlign = 'center'; }
    var targetCell = skillRows[i].querySelector('.total-cell');
    if (targetCell) targetCell.textContent = skill.target;
  });

  // Pool summary
  var poolSummary = document.querySelector('.skill-pool-summary');
  if (poolSummary) {
    var spans = poolSummary.querySelectorAll('span');
    if (spans[0]) spans[0].innerHTML = '<strong>Physical:</strong> 10+BR+PC = ' + (10 + brVal + pcVal);
    if (spans[1]) spans[1].innerHTML = '<strong>Mental:</strong> 10+IN+AW+PW = ' + (10 + inVal + awVal + pwVal);
    if (spans[2]) spans[2].innerHTML = '<strong>Social:</strong> 10+SP = ' + (10 + spVal);
  }

  // Weapons
  var weaponRows = document.querySelectorAll('.weapon-table tbody tr');
  (c.weapons || []).forEach(function(w, i) {
    var row = weaponRows[i + 1]; // skip Unarmed row
    if (!row) return;
    var cells = row.querySelectorAll('td');
    if (cells[0]) cells[0].textContent = w.name;
    if (cells[1]) cells[1].textContent = w.skill;
    if (cells[2]) cells[2].textContent = w.spd;
    if (cells[3]) cells[3].textContent = w.dmg;
    if (cells[4]) cells[4].textContent = w.cap || '\u2014';
    if (cells[5]) cells[5].textContent = w.rld || '\u2014';
    if (cells[6]) cells[6].textContent = w.rel || '\u2014';
    if (cells[7]) cells[7].textContent = w.tags || '';
  });

  // Armor
  var armorRows = document.querySelectorAll('.armor-table tbody tr');
  var tBal = 0, tMar = 0, tHin = 0;
  (c.armor || []).forEach(function(a, i) {
    if (!armorRows[i]) return;
    var cells = armorRows[i].querySelectorAll('td');
    if (cells[0]) cells[0].textContent = a.name;
    if (cells[1]) cells[1].textContent = a.ballistic;
    if (cells[2]) cells[2].textContent = a.martial;
    if (cells[3]) cells[3].textContent = a.hinder;
    if (cells[4]) cells[4].textContent = a.notes || '';
    tBal += (+a.ballistic || 0);
    tMar += (+a.martial || 0);
    tHin += (+a.hinder || 0);
  });
  // Armor totals (indices 3,4,5 of derived-box after attr ones)
  if (derivedBoxes[3]) derivedBoxes[3].textContent = tBal;
  if (derivedBoxes[4]) derivedBoxes[4].textContent = tMar;
  if (derivedBoxes[5]) derivedBoxes[5].textContent = tHin;

  // Wound/exhaustion track: mark crossed boxes
  var allHpBoxes = document.querySelectorAll('.hp-box');
  // First 40 are wounds (4 tiers x 10), next 40 are exhaustion
  for (var i = 0; i < 40; i++) {
    if (allHpBoxes[i] && (i % 10) >= hpPerTier) allHpBoxes[i].classList.add('crossed');
  }
  for (var i = 40; i < 80; i++) {
    if (allHpBoxes[i] && ((i - 40) % 10) >= epPerTier) allHpBoxes[i].classList.add('crossed');
  }

  // XP
  var xpBoxes = document.querySelectorAll('.xp-box');
  if (xpBoxes[0] && c.xp) xpBoxes[0].textContent = c.xp.total || 0;
  if (xpBoxes[1] && c.xp) xpBoxes[1].textContent = c.xp.spent || 0;

  // Magic path checkboxes — clear build-time defaults, then mark the correct one
  var checkboxes = document.querySelectorAll('.checkbox');
  checkboxes.forEach(function(cb) { cb.classList.remove('checked'); });
  if (c.path === 'scholarly' && checkboxes[0]) checkboxes[0].classList.add('checked');
  if (c.path === 'wild' && checkboxes[1]) checkboxes[1].classList.add('checked');
  if (c.path === 'none' && checkboxes[2]) checkboxes[2].classList.add('checked');

  // Casting fields
  var castingValues = document.querySelectorAll('.casting-value');
  if (c.path !== 'none') {
    // Find casting target from skills
    var castSkillName = c.path === 'scholarly' ? 'Scholarly Casting' : 'Wild Casting';
    var castSkill = (c.skills || []).find(function(s) { return s.name === castSkillName; });
    if (castingValues[0] && castSkill) castingValues[0].textContent = castSkill.target;
    if (castingValues[1]) castingValues[1].textContent = (pwVal + 4) * 10;
    if (castingValues[2]) castingValues[2].textContent = c.path === 'scholarly' ? 'All' : (c.wildSchools || []).join(', ');
    if (castingValues[3]) castingValues[3].textContent = c.path === 'scholarly' ? (7 + pwVal) : 'All in selected schools';
  }

  // Spells
  var spellRows = document.querySelectorAll('.spell-table tbody tr');
  (c.spells || []).forEach(function(sp, i) {
    if (!spellRows[i]) return;
    var cells = spellRows[i].querySelectorAll('td');
    if (cells[0]) cells[0].textContent = sp.name;
    if (cells[1]) cells[1].textContent = sp.school;
    if (cells[2]) cells[2].textContent = sp.cast;
    if (cells[3]) cells[3].textContent = sp.w;
    if (cells[4]) cells[4].textContent = sp.s;
    if (cells[5]) cells[5].textContent = sp.st;
    if (cells[6]) cells[6].textContent = sp.sp;
  });

  // Inventory
  var invLines = document.querySelectorAll('.inv-line');
  var invItems = (c.inventory || '').split('\n').filter(Boolean);
  invItems.forEach(function(item, i) { if (invLines[i]) invLines[i].textContent = item; });

  // Society
  var societyLines = document.querySelectorAll('.society-grid .field-line');
  if (c.society) {
    if (societyLines[0]) societyLines[0].textContent = c.society.name || '';
    if (societyLines[1]) societyLines[1].textContent = c.society.type || '';
    if (societyLines[2]) societyLines[2].textContent = c.society.patron || '';
    if (societyLines[3]) societyLines[3].textContent = c.society.handler || '';
    if (societyLines[4]) societyLines[4].textContent = c.society.backing || '';
    // Ledger checkboxes
    if (societyLines[5]) {
      var levels = ['Flush','Level','Lean','Dire'];
      societyLines[5].innerHTML = levels.map(function(l) {
        return (c.society.ledger === l ? '&#9746;' : '&#9744;') + ' ' + l;
      }).join(' &nbsp; ');
    }
  }

  // Charter
  var charterField = document.querySelector('.society-grid + .field .field-line');
  if (charterField && c.society) charterField.textContent = c.society.charter || '';

  // Faction
  var factionSection = null;
  document.querySelectorAll('.section-title').forEach(function(t) {
    if (t.textContent.trim() === 'Faction Alignment') factionSection = t.parentElement;
  });
  if (factionSection) {
    var fLines = factionSection.querySelectorAll('.field-line');
    if (fLines[0]) fLines[0].textContent = c.faction || '';
    if (fLines[1]) fLines[1].textContent = c.factionRelation || '';
  }

  // Contacts
  var contactRows = document.querySelectorAll('.contact-row');
  (c.contacts || []).forEach(function(ct, i) {
    if (!contactRows[i]) return;
    var lines = contactRows[i].querySelectorAll('.field-line');
    if (lines[0]) lines[0].textContent = ct.name;
    if (lines[1]) lines[1].textContent = ct.affiliation;
    if (lines[2]) lines[2].textContent = ct.notes;
  });

  // Notes
  var notesSection = null;
  document.querySelectorAll('.section-title').forEach(function(t) {
    if (t.textContent.trim() === 'Notes') notesSection = t.parentElement;
  });
  if (notesSection) {
    var noteLines = notesSection.querySelectorAll('.notes-line');
    var noteItems = (c.notes || '').split('\n').filter(Boolean);
    noteItems.forEach(function(n, i) { if (noteLines[i]) noteLines[i].textContent = n; });
  }

})();
</script>
</body>
</html>
