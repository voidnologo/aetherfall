{%- set nav = pages | pageNav(pageId) -%}
{%- set pg = nav.current -%}
{%- set numbered = pg.num | isNumbered -%}
<!DOCTYPE html>
<html lang="en" data-theme="{{ pg.theme }}">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ pg.title }} &mdash; Aetherfall RPG</title>
<link rel="icon" href="{{ '/assets/logo/favicon.ico' | url }}">
<link rel="apple-touch-icon" href="{{ '/assets/logo/apple-touch-icon.png' | url }}">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=Source+Serif+4:ital,wght@0,400;0,600;0,700;1,400&family=JetBrains+Mono:wght@400;700&family=Cormorant+Garamond:ital,wght@0,400;0,500;0,700;1,400&display=swap" rel="stylesheet">
<link rel="stylesheet" href="css/styles.css">
{%- if extraHead %}
{{ extraHead | safe }}
{%- endif %}
</head>
<body>
<div id="atmosphere"><canvas id="particle-canvas"></canvas><div class="mist mist-1"></div><div class="mist mist-2"></div><div class="mist mist-3"></div></div>
<div id="page-transition" class="page-transition"></div>
<div class="sidebar-overlay"></div>
<aside class="sidebar">
  <div class="sidebar-brand"><img src="{{ '/assets/logo/wordmark.webp' | url }}" alt="Aetherfall" class="sidebar-logo"><div class="sidebar-subtitle">Rules Reference</div></div>
  <nav class="sidebar-nav">
    {%- for page in pages %}
    <div class="toc-chapter{% if page.id == pageId %} expanded{% endif %}">
      <a href="{{ page.file }}" class="toc-chapter-link{% if page.id == pageId %} active{% endif %}" data-page="{{ page.id }}">
        <span class="toc-number">{{ page.num }}</span>{{ page.title }}
      </a>
      {%- if page.id == pageId %}
      <ul class="toc-sections" id="toc-sections"></ul>
      {%- endif %}
    </div>
    {%- endfor %}
  </nav>
  <div class="sidebar-footer"><a href="../">&larr; Back to Aetherfall</a></div>
</aside>
<header class="site-header">
  <button class="header-toggle" aria-label="Toggle navigation"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg></button>
  <span class="header-logo"><img src="{{ '/assets/logo/monogram.webp' | url }}" alt="" class="header-logo-icon"><span class="header-logo-text">Aetherfall</span> <span>RPG</span></span>
  <span class="header-separator"></span>
  <span class="header-chapter">{% if numbered %}Chapter {{ pg.num }} &mdash; {% endif %}{{ pg.title }}</span>
</header>
<main class="main-content">
  <div class="page-content">

    <nav class="page-nav-compact">
      {%- if nav.prev %}
      <a href="{{ nav.prev.file }}">&larr; {{ nav.prev.title }}</a>
      {%- else %}
      <span></span>
      {%- endif %}
      {%- if nav.next %}
      <a href="{{ nav.next.file }}">{{ nav.next.title }} &rarr;</a>
      {%- else %}
      <span></span>
      {%- endif %}
    </nav>

    <div class="page-hero">
      <span class="page-number">{% if numbered %}Chapter {{ pg.num }}{% else %}{{ pg.num }}{% endif %}</span>
      <h1 class="page-title">{{ pg.title }}</h1>
      {%- if subtitle %}
      <p class="page-subtitle">{{ subtitle }}</p>
      {%- endif %}
    </div>

    {{ content | safe }}

    <nav class="page-nav">
      {%- if nav.prev %}
      <a href="{{ nav.prev.file }}" class="page-nav-link">
        <span class="page-nav-direction">&larr; Previous</span>
        <span class="page-nav-title">{{ nav.prev.title }}</span>
      </a>
      {%- endif %}
      {%- if nav.next %}
      <a href="{{ nav.next.file }}" class="page-nav-link page-nav-link--next">
        <span class="page-nav-direction">Next &rarr;</span>
        <span class="page-nav-title">{{ nav.next.title }}</span>
      </a>
      {%- endif %}
    </nav>
  </div>
  <footer class="site-footer"><p>Aetherfall RPG &mdash; Playtest Draft</p></footer>
</main>
<script src="js/main.js"></script>
{%- if extraFoot %}
{{ extraFoot | safe }}
{%- endif %}
</body>
</html>
