<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<meta name="theme-color" content="#080b14">
<title>Fiction &mdash; Aetherfall</title>
<meta name="description" content="Short stories set in the world of Aetherfall. Glimpses of what life is like between the Veil and the Engine.">
<link rel="icon" href="/assets/logo/favicon.ico">
<link rel="apple-touch-icon" href="/assets/logo/apple-touch-icon.png">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=Source+Serif+4:ital,wght@0,400;0,600;0,700;1,400&family=Cormorant+Garamond:ital,wght@0,400;0,500;0,700;1,400&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/fiction/css/fiction.css">
</head>
<body>

<div class="atmo"></div>

<div class="reader-bar">
  <div class="reader-bar-inner">
    <a href="/" class="back-link">&larr; Aetherfall</a>
    <a href="/rules/" class="back-link back-link--alt">The Rules &rarr;</a>
  </div>
</div>

<header class="fiction-header">
  <div class="container">
    <a href="/" class="brand-wordmark" aria-label="Aetherfall">
      <img src="/assets/logo/wordmark.webp" alt="Aetherfall">
    </a>
    <p class="brand-sub">Fiction</p>
    <p class="tagline">
      Short stories from the world between the Veil and the Engine &mdash;
      glimpses of what the rules only hint at.
    </p>
    <div class="divider">
      <span class="divider-line divider-line-l"></span>
      <span class="divider-gem"></span>
      <span class="divider-line divider-line-r"></span>
    </div>
  </div>
</header>

<main>
  <div class="container">
    <div class="fiction-list">
      {%- if fiction.stories and fiction.stories.length %}
        {%- for story in fiction.stories %}
        <a href="/fiction/{{ story.slug }}.html" class="story-card">
          <p class="story-number">Story No. {{ story.numberDisplay }}</p>
          <h2>{{ story.title }}</h2>
          <p class="story-subtitle">{{ story.subtitle }}</p>
          <p class="story-blurb">{{ story.blurb }}</p>
          <span class="story-cta">Begin Reading &rarr;</span>
        </a>
        {%- endfor %}
      {%- else %}
        <p class="fiction-empty">More stories coming soon.</p>
      {%- endif %}
    </div>
  </div>
</main>

<footer class="fiction-footer">
  <p>Aetherfall RPG &mdash; Fiction</p>
</footer>

</body>
</html>
